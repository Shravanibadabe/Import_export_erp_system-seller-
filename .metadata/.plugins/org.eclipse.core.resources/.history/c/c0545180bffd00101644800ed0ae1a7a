<%@ page language="java" contentType="text/html; charset=UTF-8"
	pageEncoding="UTF-8"%>
<%@ page import="java.util.*, model.ReportPojo"%>
<%@ taglib uri="jakarta.tags.core" prefix="c"%>

<%
String portId = (String) request.getAttribute("portId");
String filter = (String) request.getAttribute("filter");
List<ReportPojo> reports = (List<ReportPojo>) request.getAttribute("reports");
String msg = (String) request.getAttribute("msg");
%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Reported Products</title>
<link rel="stylesheet"
	href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link
	href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700;800&display=swap"
	rel="stylesheet">

<style>
:root {
	--bg1: #0a0214;
	--primary: #6c2bd9;
	--primary-200: #e6dbff;
	--primary-100: #f6f1ff;
	--pink: #ff4b91;
	--ink: #1b1b1b;
}

html, body {
	height: 100%
}

body {
	margin: 0;
	font-family: 'Poppins', sans-serif;
	background: linear-gradient(120deg, #1b1b2f, #162447, #1f4068, #451952);
	background-size: 300% 300%;
	animation: gradientShift 14s ease infinite;
	color: var(--ink);
}

@keyframes gradientShift{
  0%{background-position:0% 50%}
  50%{background-position:100% 50%}
  100%{background-position:0% 50%}
}

/* Navbar */
.navbar {
	display: flex;
	justify-content: space-between;
	align-items: center;
	background: linear-gradient(90deg, #2a1a5e, #451952);
	padding: 20px 50px;
	height: 100px;
	position: sticky;
	top: 0;
	z-index: 30;
	box-shadow: 0 4px 20px rgba(0, 0, 0, .4);
}

.navbar .logo {
	display: flex;
	align-items: center;
	font-size: 2rem;
	font-weight: 700;
	color: #ff4b91;
}

.navbar .logo img {
	height: 75px;
	width: 75px;
	margin-right: 15px;
	border-radius: 50%;
	box-shadow: 0 4px 15px rgba(255, 75, 145, .6);
	border: 2px solid rgba(255, 255, 255, .4);
}

.nav-links {
	display: flex;
	gap: 50px;
	align-items: center;
}

.nav-links a {
	color: #f8f8f8;
	text-decoration: none;
	font-weight: 500;
	font-size: 1.05rem;
	position: relative;
}

.nav-links a::after {
	content: '';
	position: absolute;
	left: 0;
	bottom: -8px;
	height: 3px;
	width: 0;
	background: #ff4b91;
	border-radius: 2px;
	transition: width .3s ease;
}

.nav-links a:hover {
	color: #ff4b91
}

.nav-links a:hover::after {
	width: 100%
}

/* Profile Button */
.profile-btn {
	background: #ff4b91;
	color: white;
	padding: 12px 20px;
	border-radius: 30px;
	font-weight: bold;
	text-decoration: none;
	transition: all 0.3s ease;
	display: flex;
	align-items: center;
	gap: 8px;
	box-shadow: 0 4px 15px rgba(255, 75, 145, 0.6);
	user-select: none;
}

.profile-btn:hover {
	background: #ff2e75;
	transform: scale(1.08);
	box-shadow: 0 6px 25px rgba(255, 75, 145, 0.8);
}

/* Page sheet */
.sheet {
	width: 92%;
	max-width: 1150px;
	margin: 72px auto 48px;
	background: #fff;
	border: 2px solid var(--primary);
	border-radius: 16px;
	box-shadow: 0 20px 60px rgba(0, 0, 0, .35);
	overflow: hidden;
}

/* Header bar */
.sheet-head {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 18px 22px;
	background: linear-gradient(90deg, var(--primary), #8b5cf6);
	color: #fff
}

.sheet-title {
	font-size: 1.25rem;
	font-weight: 800
}

.tools {
	display: flex;
	gap: 12px;
	flex-wrap: wrap
}

.select {
	appearance: none;
	background: #fff
		url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 20 20" fill="%236c2bd9"><path d="M5.5 7l4.5 5 4.5-5z"/></svg>')
		no-repeat right 12px center;
	border: 1.5px solid var(--primary-200);
	padding: 10px 36px 10px 12px;
	border-radius: 12px;
	font-weight: 700;
	color: #3c3c3c
}

.msg {
	padding: 10px 15px;
	margin: 15px;
	border-radius: 10px;
	font-weight: 600;
	color: #0f6b3d;
	background: #e9fbef;
	border: 1px solid #b8efca
}

/* Table */
.table-wrap {
	max-height: 65vh;
	overflow: auto;
	background: #fff
}

.table {
	width: 100%;
	border-collapse: separate;
	border-spacing: 0
}

.table thead th {
	position: sticky;
	top: 0;
	background: var(--primary-100);
	color: var(--primary);
	font-weight: 800;
	text-transform: uppercase;
	font-size: .9rem;
	border-bottom: 2px solid var(--primary-200);
	padding: 14px;
	text-align: center
}

.table tbody td {
	border-bottom: 1px solid var(--primary-200);
	padding: 12px;
	font-weight: 600;
	color: #3b3b3b;
	text-align: center
}

.table tbody tr:hover {
	background: #faf7ff
}

/* Status badges */
.badge {
	display: inline-block;
	padding: 6px 12px;
	border-radius: 20px;
	font-size: .8rem;
	font-weight: 800
}

.badge-pending {
	background: #fff8e6;
	border: 1px solid #ffe9a6;
	color: #795b00
}

.badge-resolved {
	background: #e9fbef;
	border: 1px solid #b8efca;
	color: #0f6b3d
}

/* Pills */
.pill {
	display: inline-flex;
	align-items: center;
	gap: 6px;
	padding: 6px 12px;
	border-radius: 999px;
	font-weight: 700;
	font-size: .85rem;
	text-decoration: none;
	cursor: pointer
}

.pill-resolve {
	border: 2px solid #b6f7c9;
	color: #0f6b3d;
	background: #eafff1
}

.pill-disabled {
	color: #999
}

/* Empty */
.empty {
	padding: 48px;
	text-align: center;
	color: #6b7280;
	font-weight: 600
}

.empty i {
	font-size: 40px;
	color: var(--primary);
	margin-bottom: 12px
}

/* Modal */
.modal-backdrop {
	background: rgba(0, 0, 0, 0.6)
}

.modal {
	position: fixed;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
	display: none;
	align-items: center;
	justify-content: center;
	z-index: 1000
}

.modal.active {
	display: flex
}

.modal-box {
	background: #fff;
	padding: 20px;
	border-radius: 14px;
	max-width: 400px;
	width: 100%;
	box-shadow: 0 8px 30px rgba(0, 0, 0, .3)
}

.modal-header {
	font-weight: 800;
	font-size: 1.1rem;
	margin-bottom: 10px
}

.modal-actions {
	display: flex;
	justify-content: flex-end;
	gap: 12px;
	margin-top: 20px
}

.btn {
	padding: 8px 14px;
	border-radius: 8px;
	font-weight: 700;
	cursor: pointer;
	border: none
}

.btn-cancel {
	background: #eee
}

.btn-confirm {
	background: #6c2bd9;
	color: #fff
}
</style>
</head>
<body>

	<!-- Navbar -->
	<div class="navbar">
		<div class="logo">
			<img src="image/logo.png" alt="Logo"><span>ImportExportERP</span>
		</div>
		<div class="nav-links">
			<a
				href="http://localhost:8080/RegistrationLogin/dashboard.jsp?port_id=${portId}"
				class="nav-link">Home</a> <a
				href="http://localhost:8080/ProductManagement/ProductServlet"
				class="nav-link">Product Management</a> <a
				href="http://localhost:8080/OrderManagement/ListOrdersServlet?seller_port_id=${portId}"
				class="nav-link">Order Management</a> <a
				href="http://localhost:8080/Report_product/ReportedProductsServlet?port_id=${portId}"
				class="nav-link">Reported Products</a>
		</div>
		<div class="nav-cta">
			<a
				href="http://localhost:8080/ProfileManagement/ProfileController?port_id=${portId}"
				class="profile-btn"> <i class="fa-solid fa-user"></i> Profile
			</a>
		</div>
	</div>

	<!-- White Sheet -->
	<div class="sheet">
		<div class="sheet-head">
			<div class="sheet-title">
				<i class="fa-solid fa-flag"></i> Reported Products
			</div>
			<div class="tools">
				<form method="get" action="ReportedProductsServlet">
					<select class="select" name="filter" onchange="this.form.submit()">
						<option value="all"
							<%=(filter == null || "all".equals(filter)) ? "selected" : ""%>>All</option>
						<option value="pending"
							<%="pending".equals(filter) ? "selected" : ""%>>Pending</option>
						<option value="resolved"
							<%="resolved".equals(filter) ? "selected" : ""%>>Resolved</option>
					</select>
				</form>
				<input id="q" type="text" class="select" placeholder="Search report, product, reason…">
<button class="btn btn-confirm" onclick="window.print()">
  <i class="fa-solid fa-print"></i>
</button>
				
			</div>
		</div>

		<%
		if (msg != null && !msg.isEmpty()) {
		%>
		<div class="msg"><%=msg%></div>
		<%
		}
		%>

		<!-- Table -->
		<div class="table-wrap">
			<table class="table">
				<thead>
					<tr>
						<th>Report ID</th>
						<th>Product ID</th>
						<th>Reporter ID</th>
						<th>Reason</th>
						<th>Reported At</th>
						
						<th>Status</th>
						<th>Actions</th>
					</tr>
				</thead>
				<tbody>
					<c:choose>
						<c:when test="${not empty reports}">
							<c:forEach var="r" items="${reports}">
								<tr>
									<td>${r.reportId}</td>
									<td>${r.productId}</td>
									<td>${r.reporterId}</td>
									<td>${r.reason}</td>
									<td>${r.reportedAt}</td>
									
									<td><c:choose>
											<c:when test="${r.status eq 'resolved'}">
												<span class="badge badge-resolved">Resolved</span>
											</c:when>
											<c:otherwise>
												<span class="badge badge-pending">Pending</span>
											</c:otherwise>
										</c:choose></td>
									<td><c:choose>
											<c:when test="${r.status ne 'resolved'}">
												<button type="button" class="pill pill-resolve"
													onclick="openModal('${r.reportId}')">
													<i class="fa-solid fa-check"></i> Resolve
												</button>
											</c:when>
											<c:otherwise>
												<span class="pill pill-disabled">-</span>
											</c:otherwise>
										</c:choose></td>
								</tr>
							</c:forEach>
						</c:when>
						<c:otherwise>
							<tr>
								<td colspan="6"><div class="empty">
										<i class="fa-solid fa-box-open"></i><br>No reports found.
									</div></td>
							</tr>
						</c:otherwise>
					</c:choose>
				</tbody>
			</table>
		</div>
	</div>

	<!-- Modals -->
	<c:forEach var="r" items="${reports}">
		<c:if test="${r.status ne 'resolved'}">
			<div class="modal" id="modal-${r.reportId}">
				<div class="modal-box">
					<div class="modal-header">Confirm Resolve</div>
					<div>Are you sure you want to mark this report as resolved?</div>
					<div class="modal-actions">
						<button class="btn btn-cancel"
							onclick="closeModal('${r.reportId}')">Cancel</button>
						<form method="post" action="ResolveReportServlet">
							<input type="hidden" name="report_id" value="${r.reportId}">
							<input type="hidden" name="filter" value="${filter}">
							<button type="submit" class="btn btn-confirm">Yes,
								Resolve</button>
						</form>
					</div>
				</div>
			</div>
		</c:if>
	</c:forEach>

	<script>
		function openModal(id) {
			document.getElementById('modal-' + id).classList.add('active');
		}
		function closeModal(id) {
			document.getElementById('modal-' + id).classList.remove('active');
		}
		const q = document.getElementById('q');
		const rows = document.querySelectorAll('.table tbody tr');

		function normalize(s){ return (s||'').toLowerCase().trim(); }

		function applySearch(){
		  const term = normalize(q.value);
		  rows.forEach(r=>{
		    const text = normalize(r.innerText);
		    r.style.display = text.includes(term) ? '' : 'none';
		  });
		}
		if(q){
		  q.addEventListener('input', applySearch);
		}
	</script>

</body>
</html>
