<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ page import="java.util.List" %>
<%@ page import="jakarta.servlet.http.Cookie" %>
<%@ page import="models.Product_pojo" %>
<%
    String portId = null;
    Cookie[] cookies = request.getCookies();
    if(cookies != null){
        for(Cookie c : cookies){
            if("port_id".equals(c.getName())){
                portId = c.getValue();
                break;
            }
        }
    }
    if(portId == null){
        response.sendRedirect("login.jsp");
        return;
    }
%>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Professional Seller Dashboard</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
<style>
    body { font-family:'Poppins',sans-serif; background: linear-gradient(120deg,#1b1b2f,#162447,#1f4068); color:white; min-height:100vh; display:flex; flex-direction:column; }
    .navbar { display:flex; justify-content:space-between; align-items:center; background: linear-gradient(90deg,#2a1a5e,#451952); padding:20px 50px; height:100px; position:sticky; top:0; z-index:1000; box-shadow:0 4px 20px rgba(0,0,0,0.4);}
    .navbar .logo { display:flex; align-items:center; font-size:2rem; font-weight:700; color:#ff4b91; letter-spacing:1px;}
    .navbar .logo img { height:75px; width:75px; margin-right:15px; border-radius:50%; box-shadow:0 4px 15px rgba(255,75,145,0.6); border:2px solid rgba(255,255,255,0.4);}
    .nav-links { display:flex; gap:50px;}
    .nav-links a { color:#f8f8f8; text-decoration:none; font-weight:500; font-size:1.1rem; position:relative; transition:all 0.3s ease;}
    .nav-links a::after { content:''; position:absolute; width:0%; height:3px; background:#ff4b91; left:0; bottom:-8px; transition:all 0.3s ease; border-radius:2px;}
    .nav-links a:hover { color:#ff4b91;}
    .nav-links a:hover::after { width:100%;}
    .nav-cta { display:flex; gap:14px; }
    .btn-profile { background:#ff4b91; color:white; padding:12px 20px; border-radius:30px; font-weight:bold; text-decoration:none; transition:all 0.3s ease; display:flex; align-items:center; gap:8px; box-shadow:0 4px 15px rgba(255,75,145,0.4);}
    .btn-profile:hover { background:#ff2e75; transform:scale(1.07); box-shadow:0 6px 25px rgba(255,75,145,0.6); }

    .card { background: rgba(255, 255, 255, 0.95); border-radius:20px; box-shadow:0 10px 20px rgba(0,0,0,0.2);}
    .card-header { background: linear-gradient(45deg, #1C2833, #2E4053); color:white; border-top-left-radius:20px; border-top-right-radius:20px; padding:1.5rem; }
    .table { border-radius: 15px; overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.1);}
    .table thead { background: linear-gradient(90deg, #5D6D7E, #2C3E50); color:white;}
    .table tbody tr:hover { background-color:#f1f1f1; color:#000; }

    .btn { border-radius:12px; font-weight:bold; transition:all 0.3s ease; }
    .btn-success { background-color:#2ECC71; border-color:#2ECC71; }
    .btn-warning { background-color:#F1C40F; border-color:#F1C40F; }
    .btn-danger { background-color:#E74C3C; border-color:#E74C3C; }
    .btn-info { background-color:#3498DB; border-color:#3498DB; color:white; }

    footer { background:#16222A; color:white; text-align:center; padding:15px 0; margin-top:auto; border-top:1px solid rgba(255,255,255,0.1);}
</style>
</head>
<body>

<div class="navbar">
    <div class="logo">
        <img src="image/logo.png" alt="Logo">
        <span>ImportExportERP</span>
    </div>
        <div class="nav-links">
        <a href="http://localhost:8080/RegistrationLogin/dashboard.jsp?port_id=<%= portId %>" class="nav-link">Home</a>
       <a href="http://localhost:8080/ProductManagement/ProductServlet" class="nav-link">
    Product Management
</a>
        <a href="http://localhost:8080/OrderManagement/ListOrdersServlet?seller_port_id=<%= portId%>" class="nav-link">
    Order Management
</a>
        <a href="http://localhost:8080/Report_product/ReportedProductsServlet?port_id=<%= portId%>" class="nav-link">
    Reported Products
</a>
    </div>
    <div class="nav-cta">
        <a href="http://localhost:8080/ProfileManagement/ProfileController?port_id=<%= portId %>" class="btn btn-profile">Profile</a>
    </div>
</div>
<div class="container my-5">
    <%-- Display Message --%>
    <%
        String msg = (String) request.getAttribute("message");
        if (msg != null && !msg.isEmpty()) {
    %>
        <div class="alert <%= msg.startsWith("❌") ? "alert-danger" : "alert-success" %> text-center fw-bold rounded-3">
            <%= msg %>
        </div>
    <%
        }
    %>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card p-4 my-4">
                <div class="card-header text-center py-4">
                    <h3 class="mb-0 text-white">Manage Products</h3>
                </div>
                <div class="card-body">
                    <form id="productForm" method="post" action="ProductServlet">
                        <input type="hidden" id="port_id" name="port_id" value="<%= portId %>">
                        <input type="hidden" id="productId" name="productId">
                        <!-- Hidden field for original product name -->
                        <input type="hidden" id="original_productname" name="original_productname">
                        <div class="mb-3">
                            <label for="productname" class="form-label">Product Name</label>
                            <input type="text" class="form-control" id="productname" name="productname" required>
                        </div>
                        <div class="mb-3">
                            <label for="description" class="form-label">Description</label>
                            <textarea class="form-control" id="description" name="description" rows="3"></textarea>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="quantity" class="form-label">Quantity</label>
                                <input type="number" class="form-control" id="quantity" name="quantity" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="price" class="form-label">Price</label>
                                <input type="number" step="0.01" class="form-control" id="price" name="price" required>
                            </div>
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <input type="submit" class="btn btn-success" name="Add" value="Add Product">
                              <!-- Hidden actual submit buttons -->
    <input type="submit" name="Update" value="Update Product" style="display:none;">
    <input type="submit" name="Delete" value="Delete Product" style="display:none;">

    <!-- Visible buttons to trigger modal -->
    <input type="button" class="btn btn-warning" value="Update Product" onclick="showConfirm('update')">
    <input type="button" class="btn btn-danger" value="Delete Product" onclick="showConfirm('delete')">
</div>
                    </form>
                    <!-- Confirmation Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-warning text-dark">
        <h5 class="modal-title">Confirm Action</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p id="modalMessage">Are you sure you want to perform this action?</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="modalConfirmBtn">Yes</button>
      </div>
    </div>
  </div>
</div>
                    
                </div>
            </div>
        </div>
    </div>

    <%-- Product Table --%>
    <div class="card p-4 mt-5 mb-5">
        <div class="card-header text-center py-4">
            <h3 class="mb-0 text-white">Product List</h3>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle">
                    <thead>
                        <tr>
                            <th>Port ID</th>
                            <th>Product Name</th>
                            <th>Description</th>
                            <th>Quantity</th>
                            <th>Price</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody class="table-light">
                        <%
                            List<Product_pojo> products = (List<Product_pojo>) request.getAttribute("products");
                            if (products != null) {
                                for (Product_pojo product : products) {
                        %>
                        <tr>
                            <td><%= product.getSeller_port_id() %></td>
                            <td><%= product.getProductname() %></td>
                            <td><%= product.getDescription() %></td>
                            <td><%= product.getQuantity() %></td>
                            <td>₹ <%= product.getPrice() %></td>
                            <td>
                                <button class="btn btn-info btn-sm"
                                    onclick="populateForm('<%= product.getSeller_port_id() %>','<%= product.getProductId() %>','<%= product.getProductname().replace("'", "\\'") %>','<%= product.getDescription().replace("'", "\\'") %>','<%= product.getQuantity() %>','<%= product.getPrice() %>')">
                                    <i class="fa-solid fa-pen-to-square"></i> Edit
                                </button>
                                
                            </td>
                        </tr>
                        <%
                                }
                            } else {
                        %>
                        <tr><td colspan="6" class="text-center">No products found. Add a new product above.</td></tr>
                        <%
                            }
                        %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<footer>
    <div class="container">
        <p class="mb-0">© 2024 PRODUCT MANAGEMENT. All Rights Reserved.</p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
function populateForm(portId, productId, productName, description, quantity, price){
    document.getElementById('port_id').value = portId;
    document.getElementById('productId').value = productId;
    document.getElementById('productname').value = productName;
    document.getElementById('original_productname').value = productName; // store original name
    document.getElementById('description').value = description;
    document.getElementById('quantity').value = quantity;
    document.getElementById('price').value = price;
    window.scrollTo({top:0, behavior:'smooth'});
}
let actionType = '';

function showConfirm(action){
    actionType = action;
    document.getElementById('modalMessage').textContent =
        action === 'update' ? 'Are you sure you want to update this product?' :
                              'Are you sure you want to delete this product?';
    const confirmModal = new bootstrap.Modal(document.getElementById('confirmModal'));
    confirmModal.show();
}

document.getElementById('modalConfirmBtn').addEventListener('click', function(){
    const form = document.getElementById('productForm');
    if(actionType === 'update') form.querySelector('input[name="Update"]').click();
    else if(actionType === 'delete') form.querySelector('input[name="Delete"]').click();
    const confirmModal = bootstrap.Modal.getInstance(document.getElementById('confirmModal'));
    confirmModal.hide();
});
</script>
</body>
</html>
